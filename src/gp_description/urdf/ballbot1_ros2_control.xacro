<?xml version="1.0" encoding="utf-8"?>
<robot name="ballbot_gp" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ══════════════════════════════════════════════════════════════
       ros2_control HARDWARE INTERFACE

       Simulation:
         plugin: gz_ros2_control/GazeboSimSystem
         OLD (Classic): gazebo_ros2_control/GazeboSystem  ← DO NOT USE

       Real hardware (future — uncomment when STM32 bridge is ready):
         plugin: ballbot_hardware/BallbotInterface
         This will be your custom ros2_control hardware plugin that
         talks to the STM32 over USB serial.

       Velocity limits for the three omniwheel motors:
         max = 41.9 rad/s ≈ 400 RPM at 0.05 m wheel radius
         This matches the <limit velocity="41.9"/> in the URDF joints.
  ══════════════════════════════════════════════════════════════ -->

  <ros2_control name="ballbot_gp" type="system">

    <!-- ── Simulation Hardware ─────────────────────────────────── -->
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- ── Real Hardware (uncomment when STM32 bridge is ready) ──
    <hardware>
      <plugin>ballbot_hardware/BallbotInterface</plugin>
      <param name="serial_port">/dev/ttyACM0</param>
      <param name="baud_rate">115200</param>
    </hardware>
    ─────────────────────────────────────────────────────────── -->

    <!-- ── Wheel 1 ─────────────────────────────────────────────── -->
    <joint name="wheel1_joint">
      <command_interface name="velocity">
        <param name="min">-41.9</param>
        <param name="max">41.9</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- ── Wheel 2 ─────────────────────────────────────────────── -->
    <joint name="wheel2_joint">
      <command_interface name="velocity">
        <param name="min">-41.9</param>
        <param name="max">41.9</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- ── Wheel 3 ─────────────────────────────────────────────── -->
    <joint name="wheel3_joint">
      <command_interface name="velocity">
        <param name="min">-41.9</param>
        <param name="max">41.9</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

</robot>
